{
  "name": "mcp-server",
  "version": "1.2.2-rc.3",
  "description": "MCP server for BookMe API",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "ci": "pnpm run build && vitest run --coverage --reporter=junit --outputFile=junit.xml; node ../utility/patch-junit-xml.js junit.xml; pnpm dlx junit-to-ctrf -o ../ctrf/mcp-server-ctrf.json junit.xml; node ../utility/patch-ctrf.js ../ctrf/mcp-server-ctrf.json",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sentry/node": "10.36.0",
    "@sentry/profiling-node": "10.36.0",
    "axios": "^1.13.5",
    "common": "file:../common",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "hono": "^4.11.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
